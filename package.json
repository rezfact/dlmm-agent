{
  "name": "meridian",
  "version": "1.0.0",
  "type": "module",
  "description": "Meridian — autonomous Meteora DLMM liquidity agent for Solana (LLM-powered)",
  "main": "index.js",
  "bin": {
    "meridian": "cli.js"
  },
  "scripts": {
    "setup": "node setup.js",
    "start": "node index.js",
    "dev": "DRY_RUN=true node index.js",
    "test:screen": "node test/test-screening.js",
    "test:agent": "DRY_RUN=true node test/test-agent.js",
    "test:smoke": "node test/test-screening.js && DRY_RUN=true node test/test-agent.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f meridian",
    "docker:test": "docker compose run --rm --no-deps meridian node -e \"import('./config.js').then(m => console.log('Docker smoke OK — deployAmountSol=', m.config.management.deployAmountSol)).catch(e => { console.error(e); process.exit(1); })\"",
    "postinstall": "node scripts/patch-anchor.js"
  },
  "dependencies": {
    "@meteora-ag/dlmm": "1.9.4",
    "@solana/spl-token": "^0.3.11",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.3.1",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
