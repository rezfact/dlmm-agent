# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Solana RPC ─────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Option A: OpenRouter only (LLM_BASE_URL unset → OpenRouter) — SCREENER + MANAGER + GENERAL all use cloud.
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here
# Default OpenRouter model id when the *primary* LLM_BASE_URL is OpenRouter (see config OPENROUTER_DEFAULT_MODEL).
# When LLM_BASE_URL is Ollama + MERIDIAN_MANAGER_OPENROUTER=1, the same default applies to **MANAGER on OpenRouter only**;
# SCREENER/GENERAL stay on Ollama. Override MANAGER cloud model: MERIDIAN_MANAGER_MODEL=...
# OPENROUTER_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# Alias: LLM_OPENROUTER_MODEL=...
# On 502/503/529 the agent may switch to LLM_BUDGET_MODEL or LLM_BUDGET_FALLBACK_MODEL (default: arcee-ai/trinity-large-preview:free).
# Ollama + OpenRouter MANAGER + daily limits: docs/llm-ollama-openrouter-manager-notes.md
#
# “Degen”-style preset (smaller deploys, 15m screening, OpenRouter MiniMax free): copy
# user-config.preset-degen.example.json → meridian-data/user-config.json and set rpcUrl / telegramChatId.
# Prefer OPENROUTER_API_KEY here over llmApiKey in JSON (avoid committing keys).

# Option B: Anthropic direct — uncomment these and comment out OPENROUTER_API_KEY
# LLM_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
# LLM_MODEL=claude-haiku-3-5

# Option C: LM Studio (local) — uncomment these and comment out OPENROUTER_API_KEY
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-model-name-from-lmstudio

# Option D: Ollama (local) — SCREENER + GENERAL (+ MANAGER when OpenRouter off / cooldown) use this endpoint
# 1) ollama pull qwen2.5:3b   (or any model; name must match `ollama list` exactly)
# 2) Point Meridian at Ollama’s OpenAI-compatible API:
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:3b
# Optional: override small default (must match a pulled model)
# LLM_LOCAL_MODEL=qwen2.5:7b
# 3) Do NOT set LLM_HYBRID=true unless you also configure a second endpoint.
# 4) Ollama-only (no OpenRouter MANAGER): you can omit OPENROUTER_API_KEY. If MERIDIAN_MANAGER_OPENROUTER=1, keep OPENROUTER_API_KEY (or LLM_MANAGER_OPENROUTER_KEY).
# 5) Meridian in Docker — pick ONE:
#    A) Ollama on the host machine:
#       LLM_BASE_URL=http://host.docker.internal:11434/v1
#       (docker-compose.yml already maps host.docker.internal via extra_hosts)
#    B) Ollama in Docker too: both must share a user-defined network (default bridge
#       does not resolve container names). Example:
#       docker network ls
#       docker inspect <ollama_container> --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}} {{end}}'
#       docker network connect <that_network_name> meridian
#       LLM_BASE_URL=http://<ollama_container_name>:11434/v1
#       Test from Meridian: docker compose exec meridian wget -qO- http://<ollama_container_name>:11434/api/tags
#    Or add an `external` network to docker-compose.yml (see commented block there) so compose joins Ollama’s network.
# Optional tuning when LLM_BASE_URL is NOT OpenRouter (Ollama/LM Studio — auto lower step/token limits).
# Defaults (if unset): maxSteps=10, screeningMaxSteps=12, maxTokens=1536, 2 preloaded candidates — fits default Ollama ctx.
# Screening no longer forces max_tokens≥2048 on local (that blew 4k ctx); cloud OpenRouter still uses max(2048, maxTokens).
# Raise only if you use a larger num_ctx / GPU; lower further if you still see truncation in Ollama logs.
# LLM_LOCAL_MAX_STEPS=10
# LLM_LOCAL_SCREENING_MAX_STEPS=12
# LLM_LOCAL_MAX_TOKENS=1536
# LLM_SCREENING_CANDIDATE_LIMIT=2
# Ollama HTTP client timeout (ms) when LLM_BASE_URL is not OpenRouter — default 32m (CPU inference can be slow).
# LLM_HTTP_TIMEOUT_MS=1920000
#
# Small VPS (~4 vCPU / 8 GiB + Ollama on CPU): slimmer preloads + lower step/token defaults (overridable above).
# Strongly pair with MERIDIAN_MANAGER_OPENROUTER=1 so closes/claims stay fast on free cloud while SCREENER stays local.
# MERIDIAN_VPS_PROFILE=small
#
# Override priority (local Ollama + MERIDIAN_VPS_PROFILE=small):
#   1) Env LLM_LOCAL_MAX_STEPS / LLM_LOCAL_SCREENING_MAX_STEPS / LLM_LOCAL_MAX_TOKENS — only used when
#      user-config.json omits maxSteps / screeningMaxSteps / maxTokens (same as before).
#   2) user-config.json maxSteps, screeningMaxSteps, maxTokens, screeningCandidateLimit, screeningNarrativeMaxChars,
#      screeningHoldersLimit, toolResultMaxChars — if set HIGHER than small-VPS safe ceilings, startup clamps them
#      and logs "VPS cap: …" (e.g. old preset maxSteps: 36 → 10). Remove those keys to use env/defaults.
#   3) MERIDIAN_SCREENING_* / MERIDIAN_TOOL_RESULT_MAX env — applied before caps; caps still bound absurd values.
# To disable small-VPS clamping but keep Ollama: unset MERIDIAN_VPS_PROFILE (or use a beefier host + larger num_ctx).
# Optional fine-grain (defaults follow VPS profile when unset):
# MERIDIAN_SCREENING_NARRATIVE_MAX=100
# MERIDIAN_SCREENING_HOLDERS_LIMIT=35
# MERIDIAN_TOOL_RESULT_MAX=4000
# Caveman / terse system-prompt block (fewer tokens on wire; no Ollama change):
#   Local: default ON when LLM_BASE_URL is not OpenRouter (see user-config.json terseCaveman).
#   Cloud: set MERIDIAN_CAVEMAN=1 or MERIDIAN_CAVEMAN_LEVEL=lite|full|ultra to inject the block.
#   MERIDIAN_CAVEMAN=0 disables forced caveman; MERIDIAN_CAVEMAN_LEVEL=off disables entirely.
#   LLM_TERSE=1 is an alias for terse defaults in config. See .agents/skills/caveman/SKILL.md.
# MERIDIAN_CAVEMAN=1
# MERIDIAN_CAVEMAN=0
# Intensity for system prompt injection (local + cloud): lite | full | ultra | off
# MERIDIAN_CAVEMAN_LEVEL=full
#
# When LLM_BASE_URL is Ollama/LM Studio: run MANAGEMENT cycles on OpenRouter (fast), until rate limit / quota:
#   MERIDIAN_MANAGER_OPENROUTER=1
#   OPENROUTER_API_KEY=sk-or-...          # or LLM_MANAGER_OPENROUTER_KEY for a separate key
#   MERIDIAN_MANAGER_MODEL=nvidia/nemotron-3-super-120b-a12b:free   # optional; overrides cloud MANAGER only
#   MERIDIAN_MANAGER_OPENROUTER_COOLDOWN_HOURS=12      # after HTTP 429/402, MANAGER uses local LLM for this many hours
# Screener + Telegram still use LLM_BASE_URL (Ollama). Tune Ollama RAM/CPU in docker-compose.ollama.example.yml.

# Option E: Hybrid — Claude (or any premium base URL) for MANAGER; OpenRouter for SCREENER + Telegram
# LLM_HYBRID=true
# LLM_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5
# OPENROUTER_API_KEY=sk-or-...   # required for budget side (or set LLM_BUDGET_API_KEY only)
# Optional: LLM_BUDGET_BASE_URL=https://openrouter.ai/api/v1
# Optional: LLM_BUDGET_MODEL=...  (hybrid / retry; defaults to OPENROUTER_DEFAULT_MODEL when unset)
# Optional: LLM_BUDGET_FALLBACK_MODEL=arcee-ai/trinity-large-preview:free

# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
LPAGENT_API_KEY=your_lpagent_api_key_here
JUPITER_API_KEY=your_jupiter_api_key_here

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Misc ───────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=info

# ── Docker (optional) ───────────────────────────────────────────────────────────
# Persistent state volume path inside the container (set by docker-compose.yml)
# MERIDIAN_DATA_DIR=/data

# ── LLM cost / efficiency ───────────────────────────────────────────────────────
# Set true to stop management cron from starting extra screening runs (screening
# only on screeningIntervalMin). Cuts Claude/OpenRouter usage a lot.
# MERIDIAN_LLM_SAVER=true
